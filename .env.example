# --- Fireworks AI (reasoning: lessons, quizzes, prerequisite inference, concept extraction) ---
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# --- Gemma, served locally via vLLM-ROCm or Ollama (concept extraction) ---
GEMMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER controls the backend for concept extraction and embeddings:
#   "fireworks" — Fireworks AI hosted API (default hosted path)
#   "openai"    — OpenAI GPT-4o mini (prototyping-only)
#   unset       — local Gemma via vLLM-ROCm/Ollama + SentenceTransformer
LLM_PROVIDER=fireworks
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend / API ---
API_PORT=8000

# --- GPU worker (AMD ROCm) ---
ROCM_VISIBLE_DEVICES=0
GPU_WORKER_URL=http://gpu-worker:8100

# --- Optional: web search for gap-filling agent ---
WEB_SEARCH_API_KEY=

DB_URL=postgresql://user:password@localhost:5432/atlas

# --- Authentication ---
JWT_SECRET=your-super-secret-jwt-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# --- Admin Account (for seeding) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=

# --- Gemini AI (Quiz generation) ---
GEMINI_API_KEY=
