# --- Fireworks AI (reasoning: lessons, quizzes, prerequisite inference) ---
FIREWORKS_API_KEY=

# --- Gemma, served locally via vLLM-ROCm or Ollama (concept extraction) ---
GEMMA_BASE_URL=http://localhost:11434

# --- Prototyping-only: set LLM_PROVIDER=openai to route concept
# extraction (step 2), prerequisite inference (step 4), and lesson/quiz
# generation (step 7) through OpenAI (GPT-4o mini by default) instead of
# Gemma/Fireworks, to validate the pipeline end-to-end before real AMD
# ROCm/Fireworks infrastructure is provisioned. Leave unset (or anything
# other than "openai") for the real submission path. See
# docs/hackathon-scope.md §5.
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend / API ---
API_PORT=8000

# --- GPU worker (AMD ROCm) ---
ROCM_VISIBLE_DEVICES=0
GPU_WORKER_URL=http://gpu-worker:8100

# --- Optional: web search for gap-filling agent ---
WEB_SEARCH_API_KEY=
